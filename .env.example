# ============================================================
# Smart Speaker — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际的 API Key
#   cp .env.example .env
# ============================================================

# DeepSeek API Key (必需)
# 注册地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 和风天气 API Key (可选, 天气技能需要)
# 注册地址: https://dev.qweather.com/
WEATHER_API_KEY=your-qweather-api-key

# 百度 ASR (可选, 云端识别备用)
# 注册地址: https://ai.baidu.com/tech/speech
BAIDU_APP_ID=your-baidu-app-id
BAIDU_API_KEY=your-baidu-api-key
BAIDU_SECRET_KEY=your-baidu-secret-key

# 阿里云 ASR (可选, 云端识别备用)
# 注册地址: https://ai.aliyun.com/nls
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_APP_KEY=your-aliyun-app-key
