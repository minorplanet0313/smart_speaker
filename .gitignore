# ============================================================
# Smart Speaker — .gitignore
# ============================================================

# 敏感信息
.env
*.key
*.pem

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# 虚拟环境
venv/
smart_speaker_venv/
env/

# AI 模型 (大的忽略, 小的唤醒词模型追踪)
models/
!models/openwakeword/
!models/openwakeword/*.onnx
!models/openwakeword/*.tflite

# 数据
data/logs/
data/conversations/
data/cache/
data/debug_audio/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 系统文件
.DS_Store
Thumbs.db

# 临时文件
/tmp/
*.tmp
*.temp
1.txt
.python-version
